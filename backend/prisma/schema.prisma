// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String
  displayName   String?
  avatar        String?
  bio           String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  uploadedAudio Audio[]   @relation("UploadedBy")
  playlists      Playlist[]
  favorites      Favorite[]
  recentPlays    RecentPlay[]
  queue          Queue?
}

model Audio {
  id            String    @id @default(cuid())
  title         String
  artist        String
  album         String?
  genre         String?
  duration      Int       // Duration in seconds
  fileSize      Int       // File size in bytes
  format        String    // File format (mp3, wav, etc.)
  filePath      String    // Path to audio file
  coverArt      String?   // Path to cover art image
  waveform      String?   // Path to waveform data
  playCount     Int       @default(0)
  uploadedById  String
  uploadedBy    User      @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  playlistTracks PlaylistTrack[]
  favorites      Favorite[]
  recentPlays    RecentPlay[]
  queueItems     QueueItem[]
  
  @@index([artist])
  @@index([album])
  @@index([genre])
  @@index([title])
}

model Playlist {
  id          String    @id @default(cuid())
  name        String
  description String?
  coverArt    String?
  isPublic    Boolean   @default(false)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  tracks      PlaylistTrack[]
  
  @@index([userId])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  audioId    String
  audio      Audio    @relation(fields: [audioId], references: [id], onDelete: Cascade)
  position   Int      // Track position in playlist
  addedAt    DateTime @default(now())
  
  @@unique([playlistId, audioId])
  @@index([playlistId])
  @@index([audioId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioId   String
  audio     Audio    @relation(fields: [audioId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, audioId])
  @@index([userId])
  @@index([audioId])
}

model RecentPlay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioId   String
  audio     Audio    @relation(fields: [audioId], references: [id], onDelete: Cascade)
  playedAt  DateTime @default(now())
  progress  Int      @default(0) // Playback progress in seconds
  
  @@index([userId])
  @@index([audioId])
}

model Queue {
  id          String      @id @default(cuid())
  userId      String      @unique
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentTrack String?
  isPlaying   Boolean     @default(false)
  isShuffled  Boolean     @default(false)
  repeatMode  String      @default("none") // none, all, one
  volume      Float       @default(1.0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  items       QueueItem[]
  
  @@index([userId])
}

model QueueItem {
  id        String   @id @default(cuid())
  queueId   String
  queue     Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
  audioId   String
  audio     Audio    @relation(fields: [audioId], references: [id], onDelete: Cascade)
  position  Int
  addedAt   DateTime @default(now())
  
  @@unique([queueId, position])
  @@index([queueId])
  @@index([audioId])
}
